APP_SECRET=replace-with-a-unique-random-value-of-at-least-32-characters
POSTGRES_PASSWORD=replace-with-a-url-safe-postgres-password
DATABASE_URL=postgres://composebastion:composebastion@postgres:5432/composebastion
REDIS_URL=redis://redis:6379
BACKUP_DIR=/data/backups

# Used by docker-compose.image.yml. Use latest for simple homelab/NAS updates,
# or pin the latest published release, currently 1.0.6, for production change control.
COMPOSEBASTION_IMAGE=ghcr.io/composebastion-admin/composebastion-app
COMPOSEBASTION_VERSION=latest
COMPOSEBASTION_HTTP_PORT=8080

# Used by agent-compose.image.example.yml on managed Docker hosts.
# Use latest with main-tracking installs or pin to the manager release, e.g. 1.0.6.
COMPOSEBASTION_AGENT_IMAGE=ghcr.io/composebastion-admin/composebastion-agent
COMPOSEBASTION_AGENT_VERSION=latest
COMPOSEBASTION_AGENT_PORT=8090

COMPOSEBASTION_BACKUP_DIR=/srv/composebastion/backups

# Optional backup archive encryption keyring. Leave empty to use APP_SECRET.
# Format: keyId:long-secret,keyId2:another-long-secret
BACKUP_ENCRYPTION_KEYS=
BACKUP_ENCRYPTION_ACTIVE_KEY_ID=app_secret

# Optional comma-separated absolute roots for SSH host-path backups/restores.
# Leave empty to allow any non-root absolute path for operator actions.
BACKUP_HOST_PATH_ALLOWED_ROOTS=

# Set to true when serving ComposeBastion over HTTPS.
SECURE_COOKIES=false

API_HOST=0.0.0.0
API_PORT=8080
WEB_DIST_DIR=/app/apps/web/dist

# Optional comma-separated list of extra browser origins allowed to call the API.
# Same-origin requests always work. Localhost dev origins are allowed only outside production.
CORS_ORIGINS=
TRUST_PROXY=false

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=composebastion@example.com
HOST_CHECK_INTERVAL_MS=60000
INVENTORY_SYNC_INTERVAL_MS=300000

# Agent connection mode blocks private/loopback agent URLs in production to
# prevent request forgery. Set to true when your agents live on a private LAN.
ALLOW_PRIVATE_AGENT_URLS=false

# Alert webhooks block private/loopback URLs in production to prevent request
# forgery. Set to true only when internal webhook targets are intentional.
ALLOW_PRIVATE_WEBHOOK_URLS=false

# Set to true when S3-compatible targets must reject private/loopback endpoints.
BLOCK_PRIVATE_S3_ENDPOINTS=false

# auto (Trivy when installed), trivy, or mock. The official image ships Trivy.
IMAGE_SCANNER_PROVIDER=auto
