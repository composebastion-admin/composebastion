{
  "name": "@composebastion/api",
  "version": "1.1.0",
  "private": true,
  "license": "SEE LICENSE IN ../../LICENSE.md",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "worker:dev": "tsx watch src/worker.ts",
    "lint:migrations": "tsx src/db/checkMigrations.ts",
    "openapi:check": "tsx src/openapi/writeOpenApi.ts --check",
    "openapi:write": "tsx src/openapi/writeOpenApi.ts",
    "start": "node dist/server.js",
    "worker": "node dist/worker.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1085.0",
    "@composebastion/shared": "*",
    "@fastify/cookie": "^11.1.1",
    "@fastify/cors": "^10.1.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.3.0",
    "@fastify/websocket": "^11.3.0",
    "bcryptjs": "^3.0.3",
    "fastify": "^5.10.0",
    "ioredis": "^5.11.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "ssh2": "^1.16.0",
    "uuid": "^11.1.1",
    "yaml": "^2.9.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.13.3",
    "@types/nodemailer": "^6.4.24",
    "@types/pg": "^8.11.10",
    "@types/ssh2": "^1.15.4",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
